{
  "name": "@cynco/journals",
  "version": "0.1.0-beta.1",
  "description": "Cynco journals: framework-agnostic journal entry and account register rendering",
  "keywords": [
    "accounting",
    "cynco",
    "journal",
    "ledger",
    "register"
  ],
  "homepage": "https://github.com/hazlijohar95/cynco-oss/tree/main/packages/journals",
  "bugs": {
    "url": "https://github.com/hazlijohar95/cynco-oss/issues"
  },
  "license": "MIT",
  "author": "Cynco <hello@cynco.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hazlijohar95/cynco-oss.git",
    "directory": "packages/journals"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "dist/components/web-components.js",
    "dist/worker/worker.js",
    "dist/worker/worker-portable.js"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ],
      "react": [
        "dist/react/index.d.ts"
      ],
      "ssr": [
        "dist/ssr/index.d.ts"
      ],
      "worker": [
        "dist/worker/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    },
    "./worker/worker.js": {
      "types": "./dist/worker/worker.d.ts",
      "import": "./dist/worker/worker.js"
    },
    "./worker/worker-portable.js": {
      "types": "./dist/worker/worker-portable.d.ts",
      "import": "./dist/worker/worker-portable.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "moon run journals:prepublish"
  },
  "dependencies": {
    "@cynco/theme": "workspace:*",
    "lru_map": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/bun": "catalog:",
    "@types/jsdom": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "lightningcss": "catalog:",
    "mitata": "catalog:",
    "postcss": "catalog:",
    "postcss-calc": "catalog:",
    "postcss-nesting": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
