{
  "extends": "../../tsconfig.options.json",
  "include": ["src/**/*.ts", "test/**/*.ts", "tsdown.config.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "isolatedDeclarations": true,
    "allowJs": false,
    "checkJs": false,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "lib": ["ES2023"],
    "types": ["bun"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "."
  }
}
